# =============================================================================
# Expense Sharing System — biến môi trường
# Sao chép thành .env ở thư mục gốc project:  copy .env.example .env
# =============================================================================

# --- PostgreSQL (Docker local) ---
POSTGRES_DB=expense_sharing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- Spring Boot (local dev) ---
DB_URL=jdbc:postgresql://localhost:5432/expense_sharing
DB_USERNAME=postgres
DB_PASSWORD=postgres
JWT_SECRET=local-dev-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# CORS — local Vite. Production: URL frontend (Vercel / domain)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Free deploy: Neon + Render + Vercel ---
# Neon JDBC (bắt buộc sslmode=require):
# DB_URL=jdbc:postgresql://ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=...
# JWT_SECRET=...   # openssl rand -base64 48
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# JAVA_OPTS=-Xms128m -Xmx400m -XX:+UseSerialGC
# PORT do Render tự inject — không cần set
#
# Vercel env:
# VITE_API_BASE_URL=https://your-api.onrender.com

# --- VPS Docker (docker-compose.prod.yml) ---
# HTTP_PORT=80
# CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP,https://your-domain.com

# --- Frontend (local) ---
# Để trống = Vite proxy. Hoặc:
# VITE_API_BASE_URL=http://localhost:8080
