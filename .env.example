# =============================================================================
# Expense Sharing System — biến môi trường
# Sao chép thành .env ở thư mục gốc project:  copy .env.example .env
# =============================================================================

# --- PostgreSQL (Docker) ---
POSTGRES_DB=expense_sharing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- Spring Boot (local dev: chạy backend trên máy) ---
DB_URL=jdbc:postgresql://localhost:5432/expense_sharing
DB_USERNAME=postgres
DB_PASSWORD=postgres
JWT_SECRET=local-dev-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# CORS — local dev (Vite). Production qua Docker + Nginx: để http://your-domain hoặc IP
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Production (docker-compose.prod.yml) ---
# HTTP_PORT=80
# CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP,https://your-domain.com

# --- Frontend (local dev) ---
# Để trống = dùng Vite proxy. Hoặc: VITE_API_BASE_URL=http://localhost:8080
# VITE_API_BASE_URL=
